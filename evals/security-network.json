{
  "description": "Eval cases for network security: SSRF, open redirect, missing security headers",
  "skill": "security-network",
  "cases": [
    {
      "id": "ssrf-001",
      "name": "Server-Side Request Forgery",
      "description": "Making HTTP request to user-supplied URL",
      "code_snippet": "url = request.args.get('url')\nresponse = requests.get(url)\nreturn response.text",
      "language": "python",
      "expected_findings": [{
        "type": "ssrf",
        "line": 2,
        "description_contains": ["SSRF", "allowlist", "internal"]
      }],
      "assertions": {
        "detected_bug": true,
        "correct_severity": true,
        "actionable_fix": true
      }
    },
    {
      "id": "open-redirect-001",
      "name": "Open redirect vulnerability",
      "description": "Redirect to user-supplied URL without validation",
      "code_snippet": "return redirect(request.args.get('next'))",
      "language": "python",
      "expected_findings": [{
        "type": "open-redirect",
        "line": 1,
        "description_contains": ["open redirect", "validate", "allowlist"]
      }],
      "assertions": {
        "detected_bug": true,
        "correct_severity": true,
        "actionable_fix": true
      }
    },
    {
      "id": "missing-hsts-001",
      "name": "Missing HSTS header",
      "description": "Response without Strict-Transport-Security",
      "code_snippet": "@app.route('/api/data')\ndef get_data():\n    return jsonify({'data': sensitive_data})",
      "language": "python",
      "expected_findings": [{
        "type": "missing-security-header",
        "description_contains": ["HSTS", "Strict-Transport-Security", "HTTPS"]
      }],
      "assertions": {
        "detected_bug": true,
        "actionable_fix": true
      }
    },
    {
      "id": "cors-misconfiguration-001",
      "name": "Permissive CORS policy",
      "description": "CORS allowing all origins",
      "code_snippet": "app.use(cors({\n  origin: '*',\n  credentials: true\n}));",
      "language": "javascript",
      "expected_findings": [{
        "type": "cors-misconfiguration",
        "line": 2,
        "description_contains": ["CORS", "wildcard", "origin", "allowlist"]
      }],
      "assertions": {
        "detected_bug": true,
        "actionable_fix": true
      }
    },
    {
      "id": "insecure-http-001",
      "name": "Credentials over HTTP",
      "description": "Sending credentials over unencrypted connection",
      "code_snippet": "fetch('http://api.example.com/login', {\n  method: 'POST',\n  body: JSON.stringify({ username, password })\n});",
      "language": "javascript",
      "expected_findings": [{
        "type": "insecure-transport",
        "line": 1,
        "description_contains": ["HTTP", "HTTPS", "credentials", "sensitive"]
      }],
      "assertions": {
        "detected_bug": true,
        "actionable_fix": true
      }
    },
    {
      "id": "safe-redirect-001",
      "name": "Validated redirect",
      "description": "Redirect with allowlist validation should not be flagged",
      "code_snippet": "ALLOWED_HOSTS = ['example.com', 'app.example.com']\nnext_url = request.args.get('next')\nif urlparse(next_url).hostname in ALLOWED_HOSTS:\n    return redirect(next_url)\nreturn redirect('/')",
      "language": "python",
      "expected_findings": [],
      "assertions": {
        "no_false_positive": true
      }
    }
  ]
}
