{
  "version": "1.0",
  "description": "Eval cases for automated code review skills. Each case contains code to review and expected findings.",
  "evals": [
    {
      "id": "sql-injection-001",
      "skill": "security-injection",
      "language": "python",
      "severity": "critical",
      "category": "security",
      "subcategory": "sql-injection",
      "prompt": "def get_user(username):\n    query = f\"SELECT * FROM users WHERE username = '{username}'\"\n    cursor.execute(query)\n    return cursor.fetchone()",
      "expected_findings": [
        {
          "type": "sql-injection",
          "line": 2,
          "description_contains": ["SQL injection", "f-string", "parameterized query"]
        }
      ],
      "assertions": {
        "must_detect": true,
        "severity": "critical",
        "suggest_parameterized_query": true
      }
    },
    {
      "id": "sql-injection-002",
      "skill": "security-injection",
      "language": "javascript",
      "severity": "critical",
      "category": "security",
      "subcategory": "sql-injection",
      "prompt": "app.get('/users', (req, res) => {\n  const query = `SELECT * FROM users WHERE role = '${req.query.role}'`;\n  db.query(query, (err, results) => {\n    res.json(results);\n  });\n});",
      "expected_findings": [
        {
          "type": "sql-injection",
          "line": 2,
          "description_contains": ["SQL injection", "template literal", "parameterized"]
        }
      ],
      "assertions": {
        "must_detect": true,
        "severity": "critical",
        "suggest_parameterized_query": true
      }
    },
    {
