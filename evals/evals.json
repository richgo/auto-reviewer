  "counter_examples": [
    {
      "id": "sql-injection-safe-001",
      "skill": "security-injection",
      "language": "python",
      "code": "cursor.execute(\"SELECT * FROM users WHERE username = %s\", (username,))",
      "expected_result": "no_findings",
      "reason": "Parameterized query is safe"
    },
    {
      "id": "xss-safe-001",
      "skill": "security-injection",
      "language": "javascript",
      "code": "function Comment({ comment }) {\n  return <div>{comment}</div>;\n}",
      "expected_result": "no_findings",
      "reason": "React auto-escapes text content"
    },
    {
      "id": "command-safe-001",
      "skill": "security-injection",
      "language": "python",
      "code": "subprocess.call(['ls', directory], shell=False)",
      "expected_result": "no_findings",
      "reason": "Argument list with shell=False is safe"
    },
    {
      "id": "auth-safe-001",
      "skill": "security-auth",
      "language": "python",
      "code": "@login_required\ndef delete_post(post_id):\n    post = Post.query.get_or_404(post_id)\n    if post.author_id != current_user.id:\n        abort(403)\n    db.session.delete(post)",
      "expected_result": "no_findings",
      "reason": "Auth decorator and ownership check present"
    },
    {
      "id": "null-safe-001",
      "skill": "correctness",
      "language": "java",
      "code": "if (user != null) {\n  String name = user.getName();\n}",
      "expected_result": "no_findings",
      "reason": "Null check before dereference"
    }
  ],
  "eval_metrics": {
    "precision": "true_positives / (true_positives + false_positives)",
    "recall": "true_positives / (true_positives + false_negatives)",
    "f1_score": "2 * (precision * recall) / (precision + recall)",
    "false_positive_rate": "false_positives / (false_positives + true_negatives)"
  },
  "scoring": {
    "must_detect": 10,
    "correct_severity": 5,
    "correct_line": 3,
    "good_description": 2,
    "useful_fix_suggestion": 5,
    "false_positive_penalty": -10,
    "false_negative_penalty": -10
  }
